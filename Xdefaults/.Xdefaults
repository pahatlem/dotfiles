! rxvt-unicode -------
urxvt.font: xft:SourceCodePro-Light:size=9
urxvt.boldFont: xft:SourceCodePro-Light:size=9:Bold
urxvt.italicFont: xft:SourceCodePro-Light:size=9:Italic
urxvt.boldItalicFont: xft:SourceCodePro-Light:size=9:Bold:Italic
urxvt*termName:         rxvt
urxvt*background:       #333333
urxvt*foreground:       #f9f9f9
urxvt*scrollBar:        false
urxvt*matcher.button:   1
urxvt*matcher.button:   1
urxvt.transparent:    false
urxvt*allow_bold:    true
Xft*dpi:                96
Xft*antialias:          true
Xft*hinting:            full

URxvt*geometry: 85x11
URxvt*fading:        0
URxvt*tintColor:     #ffffff
URxvt*shading:        0
URxvt*inheritPixmap:     False

